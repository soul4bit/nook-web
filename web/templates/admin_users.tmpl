<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">Контур знаний</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        <a class="button button-ghost" href="/app">Дашборд</a>
        <a class="button button-ghost" href="/app/search">Поиск</a>
        <form method="post" action="/auth/logout">
          <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
          <button class="button button-ghost" type="submit">Выйти</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="Открыть профиль @{{.User.Name}}" title="Рейтинг: {{.User.EffectiveRating}}, звание: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="Аватар @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}}</span>
                <span class="atlas-sidebar-profile-points">Рейтинг: {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">До следующего звания &laquo;{{.User.NextRankLabel}}&raquo;: {{.User.RatingToNextRank}} очков</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">Максимальное звание достигнуто</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="Настройки профиля" title="Настройки профиля">&#9881;</a>
          </div>
          <div class="atlas-sidebar-heading">
            <p class="panel-label">Разделы</p>
            <span class="atlas-sidebar-count">{{len .Sections}}</span>
          </div>
          <p class="atlas-sidebar-hint">Быстрая навигация по базе знаний</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="Поиск по разделам и темам..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>Ничего не нашлось. Попробуйте другое слово.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-main-head">
          <p class="panel-label">Админка</p>
          <h2 class="atlas-section-title">Управление платформой</h2>
          <p class="atlas-hero-text">Переключайтесь между вкладками: структура wiki, пользователи и журнал действий.</p>
        </article>

        {{if .Error}}
          <p class="alert alert-error">{{.Error}}</p>
        {{end}}
        {{if .Success}}
          <p class="alert alert-success">{{.Success}}</p>
        {{end}}

        <nav class="atlas-admin-tabs" aria-label="Разделы админки">
          <a class="atlas-admin-tab {{if eq .AdminTab "catalog"}}atlas-admin-tab-active{{end}}" href="/app/admin/users?tab=catalog">Разделы</a>
          <a class="atlas-admin-tab {{if eq .AdminTab "users"}}atlas-admin-tab-active{{end}}" href="/app/admin/users?tab=users">Заявки и пользователи</a>
          <a class="atlas-admin-tab {{if eq .AdminTab "audit"}}atlas-admin-tab-active{{end}}" href="/app/admin/users?tab=audit">Лог действий</a>
        </nav>

        {{if eq .AdminTab "catalog"}}
        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">Разделы и подразделы</p>
          <div class="atlas-admin-wiki-grid">
            <form method="post" action="/app/admin/wiki/sections/add" class="atlas-admin-wiki-form">
              <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
              <label class="field">
                <span>Новый раздел: название</span>
                <input type="text" name="name" placeholder="Например: Observability" maxlength="80" required />
              </label>
              <label class="field">
                <span>Новый раздел: slug</span>
                <input type="text" name="slug" placeholder="observability" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" maxlength="64" required />
                <small class="field-hint">Только латиница, цифры и дефисы.</small>
              </label>
              <button class="button button-primary button-compact" type="submit">Добавить раздел</button>
            </form>

            <form method="post" action="/app/admin/wiki/subsections/add" class="atlas-admin-wiki-form">
              <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
              <label class="field">
                <span>Раздел</span>
                <select class="field-select" name="section_slug" required>
                  {{range .Sections}}
                    <option value="{{.Slug}}">{{.Name}} ({{.Slug}})</option>
                  {{end}}
                </select>
              </label>
              <label class="field">
                <span>Новый подраздел</span>
                <input type="text" name="title" placeholder="Например: Метрики и алерты" maxlength="120" required />
              </label>
              <button class="button button-primary button-compact" type="submit">Добавить подраздел</button>
            </form>
          </div>

          {{if .Sections}}
            <div class="atlas-admin-wiki-list" data-admin-section-sort data-sort-endpoint="/app/admin/wiki/sections/reorder" data-csrf-token="{{$.CSRFToken}}">
              {{range .Sections}}
                {{$section := .}}
                <article class="atlas-admin-wiki-item atlas-admin-section-card" data-section-item data-section-slug="{{$section.Slug}}" draggable="true">
                  <div class="atlas-admin-wiki-head">
                    <div class="atlas-admin-section-head-main">
                      <button class="atlas-admin-section-drag" type="button" data-section-drag-handle aria-label="Перетащить раздел" title="Перетащить раздел">↕</button>
                      <h3 class="atlas-admin-title">{{.Name}}</h3>
                      <p class="atlas-admin-meta">slug: {{.Slug}}</p>
                    </div>
                    <div class="atlas-admin-section-head-actions">
                      <form method="post" action="/app/admin/wiki/sections/delete" onsubmit="return confirm('Удалить раздел {{.Name}} ({{.Slug}})? Подразделы тоже удалятся.');">
                        <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                        <input type="hidden" name="section_slug" value="{{.Slug}}" />
                        <button class="button button-ghost button-compact atlas-danger-button" type="submit">Удалить раздел</button>
                      </form>
                    </div>
                  </div>
                  <form method="post" action="/app/admin/wiki/sections/rename" class="atlas-admin-section-rename">
                    <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                    <input type="hidden" name="tab" value="catalog" />
                    <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                    <input class="atlas-admin-inline-input" type="text" name="new_name" value="{{$section.Name}}" maxlength="80" required />
                    <button class="button button-ghost button-compact" type="submit">Переименовать раздел</button>
                  </form>
                  {{if .Subsections}}
                    <ul class="atlas-admin-wiki-sub-list">
                      {{range .Subsections}}
                        {{$subsection := .}}
                        <li class="atlas-admin-wiki-sub-item">
                          <div class="atlas-admin-wiki-sub-row">
                            <span class="atlas-admin-wiki-sub-title">{{$subsection}}</span>
                            <div class="atlas-admin-wiki-sub-actions">
                              <form method="post" action="/app/admin/wiki/subsections/move">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                                <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                                <input type="hidden" name="direction" value="up" />
                                <button class="button button-ghost button-compact" type="submit">Вверх</button>
                              </form>
                              <form method="post" action="/app/admin/wiki/subsections/move">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                                <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                                <input type="hidden" name="direction" value="down" />
                                <button class="button button-ghost button-compact" type="submit">Вниз</button>
                              </form>
                              <form method="post" action="/app/admin/wiki/subsections/delete" onsubmit="return confirm('Удалить подраздел {{$subsection}} из раздела {{$section.Name}}?');">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                                <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                                <button class="button button-ghost button-compact atlas-danger-button" type="submit">Удалить</button>
                              </form>
                            </div>
                          </div>
                          <form method="post" action="/app/admin/wiki/subsections/rename" class="atlas-admin-wiki-sub-rename">
                            <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                            <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                            <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                            <input class="atlas-admin-inline-input" type="text" name="new_title" value="{{$subsection}}" maxlength="120" required />
                            <button class="button button-ghost button-compact" type="submit">Переименовать</button>
                          </form>
                        </li>
                      {{end}}
                    </ul>
                  {{else}}
                    <p class="atlas-admin-meta">Подразделов пока нет.</p>
                  {{end}}
                </article>
              {{end}}
            </div>
            <p class="atlas-admin-sort-status" data-section-sort-status aria-live="polite" aria-atomic="true">Перетаскивайте разделы мышкой за кнопку ↕, порядок сохранится автоматически.</p>
          {{else}}
            <p class="atlas-empty">Разделы пока не добавлены.</p>
          {{end}}
        </article>
        {{end}}

        {{if eq .AdminTab "users"}}
        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">Заявки на регистрацию</p>
          {{if .PendingRequests}}
            <div class="atlas-admin-list">
              {{range .PendingRequests}}
                <article class="atlas-admin-item">
                  <div>
                    <h3 class="atlas-admin-title">{{.Name}}</h3>
                    <p class="atlas-admin-meta">{{.Email}}</p>
                    <p class="atlas-admin-meta">Создано: {{.CreatedAt.Format "02.01.2006 15:04"}}</p>
                  </div>
                  <div class="atlas-admin-actions">
                    <form method="post" action="/app/admin/registrations/approve">
                      <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                      <input type="hidden" name="request_id" value="{{.ID}}" />
                      <button class="button button-primary button-compact" type="submit">Одобрить</button>
                    </form>
                    <form method="post" action="/app/admin/registrations/reject" class="atlas-admin-reject-form">
                      <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                      <input type="hidden" name="request_id" value="{{.ID}}" />
                      <input class="atlas-admin-inline-input" type="text" name="reason" placeholder="Причина (необязательно)" maxlength="180" />
                      <button class="button button-ghost button-compact" type="submit">Отклонить</button>
                    </form>
                  </div>
                </article>
              {{end}}
            </div>
          {{else}}
            <p class="atlas-empty">Нет заявок в ожидании.</p>
          {{end}}
        </article>

        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">Список пользователей</p>
          {{if .AdminUsers}}
            <div class="atlas-admin-users-table-wrap">
              <table class="atlas-admin-users-table">
                <thead>
                  <tr>
                    <th>Пользователь</th>
                    <th>Роль</th>
                    <th>Статистика</th>
                    <th>Действия</th>
                  </tr>
                </thead>
                <tbody>
                  {{range .AdminUsers}}
                    {{$managed := .}}
                    <tr>
                      <td>
                        <p class="atlas-admin-user-name">{{.Name}}</p>
                        <p class="atlas-admin-user-email">{{.Email}}</p>
                        {{if eq .ID $.User.ID}}
                          <span class="atlas-self-chip">Это вы</span>
                        {{end}}
                      </td>
                      <td>
                        <span class="atlas-role-chip atlas-role-chip-{{.Role}}">{{.RoleLabel}}</span>
                        {{if .Blocked}}
                          <p class="atlas-admin-meta"><span class="atlas-block-chip atlas-block-chip-on">Заблокирован</span></p>
                        {{else}}
                          <p class="atlas-admin-meta"><span class="atlas-block-chip">Активен</span></p>
                        {{end}}
                      </td>
                      <td>
                        <p class="atlas-admin-meta">Статей: {{.ArticlesCount}}</p>
                        <p class="atlas-admin-meta">Создан: {{.CreatedAt.Format "02.01.2006"}}</p>
                      </td>
                      <td>
                        <div class="atlas-admin-user-actions">
                          <form method="post" action="/app/admin/users/role" class="atlas-admin-role-form">
                            <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                            <input type="hidden" name="user_id" value="{{.ID}}" />
                            <select class="field-select atlas-admin-role-select" name="role">
                              {{range $.AvailableRoles}}
                                <option value="{{.Value}}" {{if eq .Value $managed.Role}}selected{{end}}>{{.Label}}</option>
                              {{end}}
                            </select>
                            <button class="button button-ghost button-compact" type="submit">Сменить роль</button>
                          </form>
                          {{if ne .ID $.User.ID}}
                            <div class="atlas-admin-user-secondary-actions">
                              {{if .Blocked}}
                                <form method="post" action="/app/admin/users/unblock">
                                  <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                  <input type="hidden" name="user_id" value="{{.ID}}" />
                                  <button class="button button-ghost button-compact" type="submit">Разблокировать</button>
                                </form>
                              {{else}}
                                <form method="post" action="/app/admin/users/block" onsubmit="return confirm('Заблокировать пользователя {{.Email}}?');">
                                  <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                  <input type="hidden" name="user_id" value="{{.ID}}" />
                                  <button class="button button-ghost button-compact atlas-warning-button" type="submit">Блокировать</button>
                                </form>
                              {{end}}
                              <form method="post" action="/app/admin/users/delete" onsubmit="return confirm('Удалить пользователя {{.Email}}?');">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="user_id" value="{{.ID}}" />
                                <button class="button button-ghost button-compact atlas-danger-button" type="submit">Удалить</button>
                              </form>
                            </div>
                          {{end}}
                        </div>
                      </td>
                    </tr>
                  {{end}}
                </tbody>
              </table>
            </div>
          {{else}}
            <p class="atlas-empty">Пользователи пока отсутствуют.</p>
          {{end}}
        </article>
        {{end}}

        {{if eq .AdminTab "audit"}}
        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">Журнал действий админа</p>
          {{if .AdminAuditEntries}}
            <div class="atlas-admin-audit-list">
              {{range .AdminAuditEntries}}
                <article class="atlas-admin-audit-item">
                  <div class="atlas-admin-audit-head">
                    <p class="atlas-admin-audit-action">{{.ActionLabel}}</p>
                    <p class="atlas-admin-audit-time">{{.CreatedAt.Format "02.01.2006 15:04"}}</p>
                  </div>
                  <p class="atlas-admin-meta">Админ: {{.AdminName}}</p>
                  {{if .TargetEmail}}
                    <p class="atlas-admin-meta">Цель: {{.TargetEmail}}</p>
                  {{end}}
                  {{if .Details}}
                    <p class="atlas-admin-meta">{{.Details}}</p>
                  {{end}}
                </article>
              {{end}}
            </div>
          {{else}}
            <p class="atlas-empty">Журнал пока пуст.</p>
          {{end}}
        </article>
        {{end}}
      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>© Контур знаний, все права защищены.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
  <script src="{{asset "admin-wiki-sort.js"}}"></script>
</body>
</html>

