<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">–Ъ–Њ–љ—В—Г—А –Ј–љ–∞–љ–Є–є</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        <a class="button button-ghost" href="/app">–Ф–∞—И–±–Њ—А–і</a>
        <a class="button button-ghost" href="/app/search">–Я–Њ–Є—Б–Ї</a>
        <form method="post" action="/auth/logout">
          <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
          <button class="button button-ghost" type="submit">–Т—Л–є—В–Є</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="–Ю—В–Ї—А—Л—В—М –њ—А–Њ—Д–Є–ї—М @{{.User.Name}}" title="–†–µ–є—В–Є–љ–≥: {{.User.EffectiveRating}}, –Ј–≤–∞–љ–Є–µ: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="–Р–≤–∞—В–∞—А @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}} &middot; {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">ƒо {{.User.NextRankLabel}}: осталось {{.User.RatingToNextRank}}</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">ћаксимальное звание достигнуто</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="–Э–∞—Б—В—А–Њ–є–Ї–Є –њ—А–Њ—Д–Є–ї—П" title="–Э–∞—Б—В—А–Њ–є–Ї–Є –њ—А–Њ—Д–Є–ї—П">&#9881;</a>
          </div>
          <p class="panel-label">–†–∞–Ј–і–µ–ї—Л</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="–Э–∞–є—В–Є —А–∞–Ј–і–µ–ї –Є–ї–Є —В–µ–Љ—Г..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>–Э–Є—З–µ–≥–Њ –љ–µ –љ–∞—И–ї–Њ—Б—М. –Я–Њ–њ—А–Њ–±—Г–є—В–µ –і—А—Г–≥–Њ–µ —Б–ї–Њ–≤–Њ.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-main-head">
          <p class="panel-label">–Р–і–Љ–Є–љ–Ї–∞</p>
          <h2 class="atlas-section-title">–£–њ—А–∞–≤–ї–µ–љ–Є–µ –њ–ї–∞—В—Д–Њ—А–Љ–Њ–є</h2>
          <p class="atlas-hero-text">–Я–µ—А–µ–Ї–ї—О—З–∞–є—В–µ—Б—М –Љ–µ–ґ–і—Г –≤–Ї–ї–∞–і–Ї–∞–Љ–Є: —Б—В—А—Г–Ї—В—Г—А–∞ wiki, –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–Є –Є –ґ—Г—А–љ–∞–ї –і–µ–є—Б—В–≤–Є–є.</p>
        </article>

        {{if .Error}}
          <p class="alert alert-error">{{.Error}}</p>
        {{end}}
        {{if .Success}}
          <p class="alert alert-success">{{.Success}}</p>
        {{end}}

        <nav class="atlas-admin-tabs" aria-label="–†–∞–Ј–і–µ–ї—Л –∞–і–Љ–Є–љ–Ї–Є">
          <a class="atlas-admin-tab {{if eq .AdminTab "catalog"}}atlas-admin-tab-active{{end}}" href="/app/admin/users?tab=catalog">–†–∞–Ј–і–µ–ї—Л</a>
          <a class="atlas-admin-tab {{if eq .AdminTab "users"}}atlas-admin-tab-active{{end}}" href="/app/admin/users?tab=users">–Ч–∞—П–≤–Ї–Є –Є –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–Є</a>
          <a class="atlas-admin-tab {{if eq .AdminTab "audit"}}atlas-admin-tab-active{{end}}" href="/app/admin/users?tab=audit">–Ы–Њ–≥ –і–µ–є—Б—В–≤–Є–є</a>
        </nav>

        {{if eq .AdminTab "catalog"}}
        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">–†–∞–Ј–і–µ–ї—Л –Є –њ–Њ–і—А–∞–Ј–і–µ–ї—Л</p>
          <div class="atlas-admin-wiki-grid">
            <form method="post" action="/app/admin/wiki/sections/add" class="atlas-admin-wiki-form">
              <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
              <label class="field">
                <span>–Э–Њ–≤—Л–є —А–∞–Ј–і–µ–ї: –љ–∞–Ј–≤–∞–љ–Є–µ</span>
                <input type="text" name="name" placeholder="–Э–∞–њ—А–Є–Љ–µ—А: Observability" maxlength="80" required />
              </label>
              <label class="field">
                <span>–Э–Њ–≤—Л–є —А–∞–Ј–і–µ–ї: slug</span>
                <input type="text" name="slug" placeholder="observability" pattern="[a-z0-9]+(?:-[a-z0-9]+)*" maxlength="64" required />
                <small class="field-hint">–Ґ–Њ–ї—М–Ї–Њ –ї–∞—В–Є–љ–Є—Ж–∞, —Ж–Є—Д—А—Л –Є –і–µ—Д–Є—Б—Л.</small>
              </label>
              <button class="button button-primary button-compact" type="submit">–Ф–Њ–±–∞–≤–Є—В—М —А–∞–Ј–і–µ–ї</button>
            </form>

            <form method="post" action="/app/admin/wiki/subsections/add" class="atlas-admin-wiki-form">
              <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
              <label class="field">
                <span>–†–∞–Ј–і–µ–ї</span>
                <select class="field-select" name="section_slug" required>
                  {{range .Sections}}
                    <option value="{{.Slug}}">{{.Name}} ({{.Slug}})</option>
                  {{end}}
                </select>
              </label>
              <label class="field">
                <span>–Э–Њ–≤—Л–є –њ–Њ–і—А–∞–Ј–і–µ–ї</span>
                <input type="text" name="title" placeholder="–Э–∞–њ—А–Є–Љ–µ—А: –Ь–µ—В—А–Є–Ї–Є –Є –∞–ї–µ—А—В—Л" maxlength="120" required />
              </label>
              <button class="button button-primary button-compact" type="submit">–Ф–Њ–±–∞–≤–Є—В—М –њ–Њ–і—А–∞–Ј–і–µ–ї</button>
            </form>
          </div>

          {{if .Sections}}
            <div class="atlas-admin-wiki-list" data-admin-section-sort data-sort-endpoint="/app/admin/wiki/sections/reorder" data-csrf-token="{{$.CSRFToken}}">
              {{range .Sections}}
                {{$section := .}}
                <article class="atlas-admin-wiki-item atlas-admin-section-card" data-section-item data-section-slug="{{$section.Slug}}" draggable="true">
                  <div class="atlas-admin-wiki-head">
                    <div class="atlas-admin-section-head-main">
                      <button class="atlas-admin-section-drag" type="button" data-section-drag-handle aria-label="–Я–µ—А–µ—В–∞—Й–Є—В—М —А–∞–Ј–і–µ–ї" title="–Я–µ—А–µ—В–∞—Й–Є—В—М —А–∞–Ј–і–µ–ї">вЖХ</button>
                      <h3 class="atlas-admin-title">{{.Name}}</h3>
                      <p class="atlas-admin-meta">slug: {{.Slug}}</p>
                    </div>
                    <div class="atlas-admin-section-head-actions">
                      <form method="post" action="/app/admin/wiki/sections/delete" onsubmit="return confirm('–£–і–∞–ї–Є—В—М —А–∞–Ј–і–µ–ї {{.Name}} ({{.Slug}})? –Я–Њ–і—А–∞–Ј–і–µ–ї—Л —В–Њ–ґ–µ —Г–і–∞–ї—П—В—Б—П.');">
                        <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                        <input type="hidden" name="section_slug" value="{{.Slug}}" />
                        <button class="button button-ghost button-compact atlas-danger-button" type="submit">–£–і–∞–ї–Є—В—М —А–∞–Ј–і–µ–ї</button>
                      </form>
                    </div>
                  </div>
                  <form method="post" action="/app/admin/wiki/sections/rename" class="atlas-admin-section-rename">
                    <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                    <input type="hidden" name="tab" value="catalog" />
                    <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                    <input class="atlas-admin-inline-input" type="text" name="new_name" value="{{$section.Name}}" maxlength="80" required />
                    <button class="button button-ghost button-compact" type="submit">–Я–µ—А–µ–Є–Љ–µ–љ–Њ–≤–∞—В—М —А–∞–Ј–і–µ–ї</button>
                  </form>
                  {{if .Subsections}}
                    <ul class="atlas-admin-wiki-sub-list">
                      {{range .Subsections}}
                        {{$subsection := .}}
                        <li class="atlas-admin-wiki-sub-item">
                          <div class="atlas-admin-wiki-sub-row">
                            <span class="atlas-admin-wiki-sub-title">{{$subsection}}</span>
                            <div class="atlas-admin-wiki-sub-actions">
                              <form method="post" action="/app/admin/wiki/subsections/move">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                                <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                                <input type="hidden" name="direction" value="up" />
                                <button class="button button-ghost button-compact" type="submit">–Т–≤–µ—А—Е</button>
                              </form>
                              <form method="post" action="/app/admin/wiki/subsections/move">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                                <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                                <input type="hidden" name="direction" value="down" />
                                <button class="button button-ghost button-compact" type="submit">–Т–љ–Є–Ј</button>
                              </form>
                              <form method="post" action="/app/admin/wiki/subsections/delete" onsubmit="return confirm('–£–і–∞–ї–Є—В—М –њ–Њ–і—А–∞–Ј–і–µ–ї {{$subsection}} –Є–Ј —А–∞–Ј–і–µ–ї–∞ {{$section.Name}}?');">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                                <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                                <button class="button button-ghost button-compact atlas-danger-button" type="submit">–£–і–∞–ї–Є—В—М</button>
                              </form>
                            </div>
                          </div>
                          <form method="post" action="/app/admin/wiki/subsections/rename" class="atlas-admin-wiki-sub-rename">
                            <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                            <input type="hidden" name="section_slug" value="{{$section.Slug}}" />
                            <input type="hidden" name="subsection_title" value="{{$subsection}}" />
                            <input class="atlas-admin-inline-input" type="text" name="new_title" value="{{$subsection}}" maxlength="120" required />
                            <button class="button button-ghost button-compact" type="submit">–Я–µ—А–µ–Є–Љ–µ–љ–Њ–≤–∞—В—М</button>
                          </form>
                        </li>
                      {{end}}
                    </ul>
                  {{else}}
                    <p class="atlas-admin-meta">–Я–Њ–і—А–∞–Ј–і–µ–ї–Њ–≤ –њ–Њ–Ї–∞ –љ–µ—В.</p>
                  {{end}}
                </article>
              {{end}}
            </div>
            <p class="atlas-admin-sort-status" data-section-sort-status aria-live="polite" aria-atomic="true">–Я–µ—А–µ—В–∞—Б–Ї–Є–≤–∞–є—В–µ —А–∞–Ј–і–µ–ї—Л –Љ—Л—И–Ї–Њ–є –Ј–∞ –Ї–љ–Њ–њ–Ї—Г вЖХ, –њ–Њ—А—П–і–Њ–Ї —Б–Њ—Е—А–∞–љ–Є—В—Б—П –∞–≤—В–Њ–Љ–∞—В–Є—З–µ—Б–Ї–Є.</p>
          {{else}}
            <p class="atlas-empty">–†–∞–Ј–і–µ–ї—Л –њ–Њ–Ї–∞ –љ–µ –і–Њ–±–∞–≤–ї–µ–љ—Л.</p>
          {{end}}
        </article>
        {{end}}

        {{if eq .AdminTab "users"}}
        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">–Ч–∞—П–≤–Ї–Є –љ–∞ —А–µ–≥–Є—Б—В—А–∞—Ж–Є—О</p>
          {{if .PendingRequests}}
            <div class="atlas-admin-list">
              {{range .PendingRequests}}
                <article class="atlas-admin-item">
                  <div>
                    <h3 class="atlas-admin-title">{{.Name}}</h3>
                    <p class="atlas-admin-meta">{{.Email}}</p>
                    <p class="atlas-admin-meta">–°–Њ–Ј–і–∞–љ–Њ: {{.CreatedAt.Format "02.01.2006 15:04"}}</p>
                  </div>
                  <div class="atlas-admin-actions">
                    <form method="post" action="/app/admin/registrations/approve">
                      <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                      <input type="hidden" name="request_id" value="{{.ID}}" />
                      <button class="button button-primary button-compact" type="submit">–Ю–і–Њ–±—А–Є—В—М</button>
                    </form>
                    <form method="post" action="/app/admin/registrations/reject" class="atlas-admin-reject-form">
                      <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                      <input type="hidden" name="request_id" value="{{.ID}}" />
                      <input class="atlas-admin-inline-input" type="text" name="reason" placeholder="–Я—А–Є—З–Є–љ–∞ (–љ–µ–Њ–±—П–Ј–∞—В–µ–ї—М–љ–Њ)" maxlength="180" />
                      <button class="button button-ghost button-compact" type="submit">–Ю—В–Ї–ї–Њ–љ–Є—В—М</button>
                    </form>
                  </div>
                </article>
              {{end}}
            </div>
          {{else}}
            <p class="atlas-empty">–Э–µ—В –Ј–∞—П–≤–Њ–Ї –≤ –Њ–ґ–Є–і–∞–љ–Є–Є.</p>
          {{end}}
        </article>

        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">–°–њ–Є—Б–Њ–Ї –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–µ–є</p>
          {{if .AdminUsers}}
            <div class="atlas-admin-users-table-wrap">
              <table class="atlas-admin-users-table">
                <thead>
                  <tr>
                    <th>–Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—М</th>
                    <th>–†–Њ–ї—М</th>
                    <th>–°—В–∞—В–Є—Б—В–Є–Ї–∞</th>
                    <th>–Ф–µ–є—Б—В–≤–Є—П</th>
                  </tr>
                </thead>
                <tbody>
                  {{range .AdminUsers}}
                    {{$managed := .}}
                    <tr>
                      <td>
                        <p class="atlas-admin-user-name">{{.Name}}</p>
                        <p class="atlas-admin-user-email">{{.Email}}</p>
                        {{if eq .ID $.User.ID}}
                          <span class="atlas-self-chip">–≠—В–Њ –≤—Л</span>
                        {{end}}
                      </td>
                      <td>
                        <span class="atlas-role-chip atlas-role-chip-{{.Role}}">{{.RoleLabel}}</span>
                        {{if .Blocked}}
                          <p class="atlas-admin-meta"><span class="atlas-block-chip atlas-block-chip-on">–Ч–∞–±–ї–Њ–Ї–Є—А–Њ–≤–∞–љ</span></p>
                        {{else}}
                          <p class="atlas-admin-meta"><span class="atlas-block-chip">–Р–Ї—В–Є–≤–µ–љ</span></p>
                        {{end}}
                      </td>
                      <td>
                        <p class="atlas-admin-meta">–°—В–∞—В–µ–є: {{.ArticlesCount}}</p>
                        <p class="atlas-admin-meta">–°–Њ–Ј–і–∞–љ: {{.CreatedAt.Format "02.01.2006"}}</p>
                      </td>
                      <td>
                        <div class="atlas-admin-user-actions">
                          <form method="post" action="/app/admin/users/role" class="atlas-admin-role-form">
                            <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                            <input type="hidden" name="user_id" value="{{.ID}}" />
                            <select class="field-select atlas-admin-role-select" name="role">
                              {{range $.AvailableRoles}}
                                <option value="{{.Value}}" {{if eq .Value $managed.Role}}selected{{end}}>{{.Label}}</option>
                              {{end}}
                            </select>
                            <button class="button button-ghost button-compact" type="submit">–°–Љ–µ–љ–Є—В—М —А–Њ–ї—М</button>
                          </form>
                          {{if ne .ID $.User.ID}}
                            <div class="atlas-admin-user-secondary-actions">
                              {{if .Blocked}}
                                <form method="post" action="/app/admin/users/unblock">
                                  <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                  <input type="hidden" name="user_id" value="{{.ID}}" />
                                  <button class="button button-ghost button-compact" type="submit">–†–∞–Ј–±–ї–Њ–Ї–Є—А–Њ–≤–∞—В—М</button>
                                </form>
                              {{else}}
                                <form method="post" action="/app/admin/users/block" onsubmit="return confirm('–Ч–∞–±–ї–Њ–Ї–Є—А–Њ–≤–∞—В—М –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П {{.Email}}?');">
                                  <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                  <input type="hidden" name="user_id" value="{{.ID}}" />
                                  <button class="button button-ghost button-compact atlas-warning-button" type="submit">–С–ї–Њ–Ї–Є—А–Њ–≤–∞—В—М</button>
                                </form>
                              {{end}}
                              <form method="post" action="/app/admin/users/delete" onsubmit="return confirm('–£–і–∞–ї–Є—В—М –њ–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї—П {{.Email}}?');">
                                <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                                <input type="hidden" name="user_id" value="{{.ID}}" />
                                <button class="button button-ghost button-compact atlas-danger-button" type="submit">–£–і–∞–ї–Є—В—М</button>
                              </form>
                            </div>
                          {{end}}
                        </div>
                      </td>
                    </tr>
                  {{end}}
                </tbody>
              </table>
            </div>
          {{else}}
            <p class="atlas-empty">–Я–Њ–ї—М–Ј–Њ–≤–∞—В–µ–ї–Є –њ–Њ–Ї–∞ –Њ—В—Б—Г—В—Б—В–≤—Г—О—В.</p>
          {{end}}
        </article>
        {{end}}

        {{if eq .AdminTab "audit"}}
        <article class="atlas-card atlas-admin-card">
          <p class="panel-label">–Ц—Г—А–љ–∞–ї –і–µ–є—Б—В–≤–Є–є –∞–і–Љ–Є–љ–∞</p>
          {{if .AdminAuditEntries}}
            <div class="atlas-admin-audit-list">
