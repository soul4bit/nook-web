<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/static/app.css" />
  <script src="/static/auth-live.js" defer></script>
</head>
<body class="auth-page">
  <main class="auth-layout">
    <aside class="auth-aside">
      <p class="eyebrow">Knowledge Atlas</p>
      <h1 class="aside-title">Create your knowledge node</h1>
      <p class="aside-text">
        Registration creates a user instantly. Bash scene reacts to
        email and password input while you type.
      </p>

      <div class="devops-scene" data-auth-scene>
        <div class="scene-shell">
          <span class="scene-line">$ terraform apply</span>
          <span class="scene-line">module.vpc: complete after 13s</span>
          <span class="scene-line">module.cluster: complete after 22s</span>
          <span class="scene-line">Outputs: endpoint = ready</span>
          <span class="scene-line scene-line-live" data-live-email>input.email: waiting...</span>
          <span class="scene-line scene-line-live" data-live-password>input.password: waiting...</span>
          <span class="scene-line scene-line-live" data-live-event>auth.event: awaiting credentials</span>
        </div>

        <div class="scene-flow" data-live-flow>
          <span class="flow-node flow-node-1"></span>
          <span class="flow-node flow-node-2"></span>
          <span class="flow-node flow-node-3"></span>
          <span class="flow-pulse" data-live-pulse></span>
        </div>

        <div class="scene-progress" role="presentation">
          <div class="scene-progress-bar">
            <span class="scene-progress-fill" data-live-fill></span>
            <span class="scene-progress-thumb" data-live-thumb></span>
          </div>
          <span class="scene-progress-label" data-live-status>status: waiting for input</span>
        </div>
      </div>
    </aside>

    <section class="auth-card">
      <div class="brand-row">
        <div class="brand-mark">KZ</div>
        <div>
          <p class="brand-title">{{.AppName}}</p>
          <p class="brand-subtitle">Register</p>
        </div>
      </div>

      <nav class="auth-tabs" aria-label="Auth mode">
        <a href="/auth/login" class="auth-tab">Sign in</a>
        <a href="/auth/register" class="auth-tab auth-tab-active">Register</a>
      </nav>

      <h2 class="auth-title">New account</h2>
      <p class="auth-subtitle">Fill the form and start building your DevOps wiki.</p>

      {{if .Error}}
      <div class="alert alert-error">{{.Error}}</div>
      {{end}}

      <form method="post" action="/auth/register" class="auth-form" data-auth-form>
        <label class="field">
          <span>Name</span>
          <input type="text" name="name" value="{{.Name}}" placeholder="How should we call you" autocomplete="name" required />
        </label>

        <label class="field">
          <span>Email</span>
          <input type="email" name="email" value="{{.Email}}" placeholder="you@example.com" autocomplete="username" required />
        </label>

        <label class="field">
          <span>Password</span>
          <input type="password" name="password" placeholder="Minimum 10 chars" autocomplete="new-password" required />
          <small class="field-hint">Use a unique password for this service.</small>
        </label>

        <label class="field">
          <span>Confirm password</span>
          <input type="password" name="confirm_password" placeholder="Repeat password" autocomplete="new-password" required />
        </label>

        <button class="button button-primary" type="submit">Create account</button>
      </form>

      <p class="footnote">
        Already have an account?
        <a href="/auth/login">Sign in</a>
      </p>
    </section>
  </main>
</body>
</html>
