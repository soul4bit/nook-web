<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">袣芯薪褌褍褉 蟹薪邪薪懈泄</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        <a class="button button-ghost" href="/app">袛邪褕斜芯褉写</a>
        <a class="button button-ghost" href="/app/search">袩芯懈褋泻</a>
        {{if .User.IsAdmin}}
          <a class="button button-ghost" href="/app/admin/users">袗写屑懈薪泻邪</a>
        {{end}}
        <form method="post" action="/auth/logout">
          <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
          <button class="button button-ghost" type="submit">袙褘泄褌懈</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="袨褌泻褉褘褌褜 锌褉芯褎懈谢褜 @{{.User.Name}}" title="袪械泄褌懈薪谐: {{.User.EffectiveRating}}, 蟹胁邪薪懈械: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="袗胁邪褌邪褉 @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}} &middot; {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">念 {{.User.NextRankLabel}}: 铖蜞腩顸 {{.User.RatingToNextRank}}</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">锑犟桁嚯铄 玮囗桢 漕耱桡眢蝾</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="袧邪褋褌褉芯泄泻懈 锌褉芯褎懈谢褟" title="袧邪褋褌褉芯泄泻懈 锌褉芯褎懈谢褟">&#9881;</a>
          </div>
          <p class="panel-label">袪邪蟹写械谢褘</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="袧邪泄褌懈 褉邪蟹写械谢 懈谢懈 褌械屑褍..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>袧懈褔械谐芯 薪械 薪邪褕谢芯褋褜. 袩芯锌褉芯斜褍泄褌械 写褉褍谐芯械 褋谢芯胁芯.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-main-head atlas-profile-head">
          <p class="panel-label">袩褉芯褎懈谢褜</p>
          <div class="atlas-profile-head-grid">
            <div class="atlas-profile-avatar-shell" aria-hidden="true">
              {{if .User.AvatarURL}}
                <img class="atlas-profile-avatar" src="{{.User.AvatarURL}}" alt="" loading="lazy" />
              {{else}}
                <span class="atlas-profile-avatar-fallback">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
            </div>
            <div class="atlas-profile-head-copy">
              <h2 class="atlas-section-title">{{.User.Name}}</h2>
              <p class="atlas-profile-email">{{.User.Email}}</p>
              <div class="atlas-pill-row atlas-profile-pills">
                <span class="atlas-pill">袪械泄褌懈薪谐: {{.User.EffectiveRating}}</span>
                <span class="atlas-pill">袟胁邪薪懈械: {{.User.RankLabel}}</span>
                <span class="atlas-pill">袪芯谢褜: {{.ProfileRoleLabel}}</span>
                {{if .ProfilePasswordChangedAt}}
                  <span class="atlas-pill">袩邪褉芯谢褜 芯斜薪芯胁谢褢薪: {{.ProfilePasswordChangedAt}}</span>
                {{else}}
                  <span class="atlas-pill">袩邪褉芯谢褜 械褖褢 薪械 屑械薪褟谢懈</span>
                {{end}}
              </div>
              {{if .ProfilePasswordNextChangeAt}}
                <p class="atlas-profile-meta">小谢械写褍褞褖邪褟 褋屑械薪邪 锌邪褉芯谢褟 写芯褋褌褍锌薪邪 锌芯褋谢械: {{.ProfilePasswordNextChangeAt}} (芯褋褌邪谢芯褋褜: {{.ProfilePasswordWait}})</p>
              {{else}}
                <p class="atlas-profile-meta">袟写械褋褜 屑芯卸薪芯 芯斜薪芯胁懈褌褜 邪胁邪褌邪褉 懈 褋屑械薪懈褌褜 锌邪褉芯谢褜.</p>
              {{end}}
            </div>
          </div>
        </article>

        {{if .Error}}
          <p class="alert alert-error">{{.Error}}</p>
        {{end}}
        {{if .Success}}
          <p class="alert alert-success">{{.Success}}</p>
        {{end}}

        <article class="atlas-card">
          <p class="panel-label">袗胁邪褌邪褉</p>
          <div class="atlas-profile-form-grid">
            <form class="article-form atlas-profile-form" method="post" action="/app/profile/avatar">
              <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
              <label class="field">
                <span>URL 懈蟹芯斜褉邪卸械薪懈褟</span>
                <input name="avatar_url" type="url" maxlength="900" value="{{.ProfileAvatarURL}}" placeholder="https://example.com/avatar.png" />
                <small class="field-hint">袛芯锌褍褋褌懈屑褘 褌芯谢褜泻芯 邪斜褋芯谢褞褌薪褘械 褋褋褘谢泻懈 http/https. 袨褋褌邪胁褜褌械 锌褍褋褌褘屑, 褔褌芯斜褘 褍写邪谢懈褌褜 邪胁邪褌邪褉.</small>
              </label>
              <div class="atlas-actions">
                <button class="button button-primary" type="submit">小芯褏褉邪薪懈褌褜 邪胁邪褌邪褉</button>
              </div>
            </form>

            <form class="article-form atlas-profile-form" method="post" action="/app/profile/avatar/upload" enctype="multipart/form-data">
              <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
              <label class="field">
                <span>袟邪谐褉褍蟹懈褌褜 褎邪泄谢</span>
                <input class="atlas-file-input" name="avatar_file" type="file" accept="image/png,image/jpeg,image/gif,image/webp" required />
                <small class="field-hint">袩芯写写械褉卸懈胁邪褞褌褋褟 JPG/PNG/GIF/WEBP, 屑邪泻褋懈屑褍屑 5 袦袘.</small>
              </label>
              <div class="atlas-actions">
                <button class="button button-ghost" type="submit">袟邪谐褉褍蟹懈褌褜 懈 锌褉懈屑械薪懈褌褜</button>
              </div>
            </form>
          </div>
        </article>

        <article class="atlas-card">
          <p class="panel-label">小屑械薪邪 锌邪褉芯谢褟</p>
          <form class="article-form atlas-profile-form" method="post" action="/app/profile/password">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
            <label class="field">
              <span>孝械泻褍褖懈泄 锌邪褉芯谢褜</span>
              <input name="current_password" type="password" autocomplete="current-password" required />
            </label>
            <label class="field">
              <span>袧芯胁褘泄 锌邪褉芯谢褜</span>
              <input name="new_password" type="password" minlength="10" autocomplete="new-password" required />
            </label>
            <label class="field">
              <span>袩芯写褌胁械褉卸写械薪懈械 薪芯胁芯谐芯 锌邪褉芯谢褟</span>
              <input name="confirm_password" type="password" minlength="10" autocomplete="new-password" required />
            </label>
            {{if .ProfilePasswordCanChange}}
              <div class="atlas-actions">
                <button class="button button-primary" type="submit">小屑械薪懈褌褜 锌邪褉芯谢褜</button>
              </div>
            {{else}}
              <p class="atlas-profile-lock-note">小屑械薪邪 锌邪褉芯谢褟 褋械泄褔邪褋 薪械写芯褋褌褍锌薪邪. 袠薪褌械褉胁邪谢 屑械卸写褍 褋屑械薪邪屑懈: 7 写薪械泄. 袨褋褌邪谢芯褋褜: {{.ProfilePasswordWait}}</p>
              <div class="atlas-actions">
                <button class="button button-primary" type="submit" disabled>小屑械薪邪 胁褉械屑械薪薪芯 薪械写芯褋褌褍锌薪邪</button>
              </div>
            {{end}}
          </form>
        </article>
      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>漏 袣芯薪褌褍褉 蟹薪邪薪懈泄, 胁褋械 锌褉邪胁邪 蟹邪褖懈褖械薪褘.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
</body>
</html>

