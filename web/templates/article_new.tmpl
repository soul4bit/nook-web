<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">–Ъ–Њ–љ—В—Г—А –Ј–љ–∞–љ–Є–є</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        <a class="button button-ghost" href="/app/section?slug={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">–Э–∞–Ј–∞–і –≤ —А–∞–Ј–і–µ–ї</a>
        <a class="button button-ghost" href="/app/search?section={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">–Я–Њ–Є—Б–Ї</a>
        {{if .User.IsAdmin}}
          <a class="button button-ghost" href="/app/admin/users">–Р–і–Љ–Є–љ–Ї–∞</a>
        {{end}}
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="–Ю—В–Ї—А—Л—В—М –њ—А–Њ—Д–Є–ї—М @{{.User.Name}}" title="–†–µ–є—В–Є–љ–≥: {{.User.EffectiveRating}}, –Ј–≤–∞–љ–Є–µ: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="–Р–≤–∞—В–∞—А @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}} &middot; {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">ƒо {{.User.NextRankLabel}}: осталось {{.User.RatingToNextRank}}</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">ћаксимальное звание достигнуто</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="–Э–∞—Б—В—А–Њ–є–Ї–Є –њ—А–Њ—Д–Є–ї—П" title="–Э–∞—Б—В—А–Њ–є–Ї–Є –њ—А–Њ—Д–Є–ї—П">&#9881;</a>
          </div>
          <p class="panel-label">–†–∞–Ј–і–µ–ї—Л</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="–Э–∞–є—В–Є —А–∞–Ј–і–µ–ї –Є–ї–Є —В–µ–Љ—Г..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>–Э–Є—З–µ–≥–Њ –љ–µ –љ–∞—И–ї–Њ—Б—М. –Я–Њ–њ—А–Њ–±—Г–є—В–µ –і—А—Г–≥–Њ–µ —Б–ї–Њ–≤–Њ.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-main-head">
          <p class="panel-label">–Э–Њ–≤–∞—П —Б—В–∞—В—М—П</p>
          <h2 class="atlas-section-title">{{.CurrentSection.Name}}</h2>
          {{if .CurrentSubsection}}
            <p class="atlas-sub-current">–Я–Њ–і—А–∞–Ј–і–µ–ї: {{.CurrentSubsection}}</p>
          {{end}}
          <p class="atlas-hero-text">–§–Њ—А–Љ–∞—В –њ—А–Њ—Б—В–Њ–є: —З—В–Њ —Б–ї—Г—З–Є–ї–Њ—Б—М, –Ї–∞–Ї–Є–µ —И–∞–≥–Є, –Ї–∞–Ї–∞—П –Ї–Њ–Љ–∞–љ–і–∞, –Ї–∞–Ї–Њ–є —А–µ–Ј—Г–ї—М—В–∞—В.</p>
        </article>

        {{if .Error}}
          <p class="alert alert-error">{{.Error}}</p>
        {{end}}
        {{if .DraftLoaded}}
          <p class="alert alert-success">–І–µ—А–љ–Њ–≤–Є–Ї –≤–Њ—Б—Б—В–∞–љ–Њ–≤–ї–µ–љ –Є–Ј –∞–≤—В–Њ—Б–Њ—Е—А–∞–љ–µ–љ–Є—П.</p>
        {{end}}

        <article class="atlas-card">
          <form class="article-form" method="post" action="/app/article/new" data-article-autosave data-autosave-endpoint="/app/article/draft/save" data-autosave-section="{{.CurrentSection.Slug}}" data-media-upload-endpoint="{{.MediaUploadEndpoint}}">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
            <input type="hidden" name="section" value="{{.CurrentSection.Slug}}" />

            <label class="field">
              <span>–Я–Њ–і—А–∞–Ј–і–µ–ї</span>
              <select class="field-select" name="subsection">
                <option value="">–С–µ–Ј –њ–Њ–і—А–∞–Ј–і–µ–ї–∞</option>
                {{range .CurrentSection.Subsections}}
                  <option value="{{.}}" {{if eq $.CurrentSubsection .}}selected{{end}}>{{.}}</option>
                {{end}}
              </select>
            </label>

            <label class="field">
              <span>–Ч–∞–≥–Њ–ї–Њ–≤–Њ–Ї</span>
              <input name="title" type="text" maxlength="180" placeholder="–Э–∞–њ—А–Є–Љ–µ—А: –Ъ–∞–Ї –њ–Њ—З–Є–љ–Є—В—М systemd unit –њ–Њ—Б–ї–µ –і–µ–њ–ї–Њ—П" value="{{.ArticleTitle}}" required />
            </label>

            <label class="field">
              <span>–Ґ–µ–Ї—Б—В —Б—В–∞—В—М–Є</span>
              <textarea name="body" data-md-editor="true" rows="15" placeholder="–Я—А–Њ–±–ї–µ–Љ–∞, —И–∞–≥–Є, –Ї–Њ–Љ–∞–љ–і–∞, –њ—А–Њ–≤–µ—А–Ї–∞ —А–µ–Ј—Г–ї—М—В–∞—В–∞...">{{.ArticleBody}}</textarea>
              <small class="field-hint">Markdown: `# –Ј–∞–≥–Њ–ї–Њ–≤–Њ–Ї`, `**–ґ–Є—А–љ—Л–є**`, `![alt](https://image-url)`</small>
            </label>

            <div class="atlas-actions">
              <button class="button button-primary" type="submit">–°–Њ—Е—А–∞–љ–Є—В—М —Б—В–∞—В—М—О</button>
              <a class="button button-ghost" href="/app/section?slug={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">–Ю—В–Љ–µ–љ–∞</a>
            </div>
            <p class="atlas-autosave-status" data-autosave-status aria-live="polite"></p>
          </form>
        </article>
      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>¬© –Ъ–Њ–љ—В—Г—А –Ј–љ–∞–љ–Є–є, –≤—Б–µ –њ—А–∞–≤–∞ –Ј–∞—Й–Є—Й–µ–љ—Л.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
  <script src="{{asset "markdown-editor.js"}}"></script>
  <script src="{{asset "editor-autosave.js"}}"></script>
</body>
</html>

