<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">Контур знаний</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        <a class="button button-ghost" href="/app/section?slug={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">Назад в раздел</a>
        <a class="button button-ghost" href="/app/search?section={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">Поиск</a>
        {{if .User.IsAdmin}}
          <a class="button button-ghost" href="/app/admin/users">Админка</a>
        {{end}}
        <a class="button button-ghost" href="/app/profile">Профиль</a>
        <a class="atlas-user-chip atlas-user-chip-link" href="/app/profile" aria-label="Открыть профиль @{{.User.Name}}">
          {{if .User.AvatarURL}}
            <img class="atlas-user-chip-avatar" src="{{.User.AvatarURL}}" alt="Аватар @{{.User.Name}}" loading="lazy" />
          {{else}}
            <span class="atlas-user-chip-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
          {{end}}
          <span class="atlas-user-chip-name">@{{.User.Name}}</span>
        </a>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <p class="panel-label">Разделы</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="Найти раздел или тему..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>Ничего не нашлось. Попробуйте другое слово.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-main-head">
          <p class="panel-label">Новая статья</p>
          <h2 class="atlas-section-title">{{.CurrentSection.Name}}</h2>
          {{if .CurrentSubsection}}
            <p class="atlas-sub-current">Подраздел: {{.CurrentSubsection}}</p>
          {{end}}
          <p class="atlas-hero-text">Формат простой: что случилось, какие шаги, какая команда, какой результат.</p>
        </article>

        {{if .Error}}
          <p class="alert alert-error">{{.Error}}</p>
        {{end}}
        {{if .DraftLoaded}}
          <p class="alert alert-success">Черновик восстановлен из автосохранения.</p>
        {{end}}

        <article class="atlas-card">
          <form class="article-form" method="post" action="/app/article/new" data-article-autosave data-autosave-endpoint="/app/article/draft/save" data-autosave-section="{{.CurrentSection.Slug}}" data-media-upload-endpoint="{{.MediaUploadEndpoint}}">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
            <input type="hidden" name="section" value="{{.CurrentSection.Slug}}" />

            <label class="field">
              <span>Подраздел</span>
              <select class="field-select" name="subsection">
                <option value="">Без подраздела</option>
                {{range .CurrentSection.Subsections}}
                  <option value="{{.}}" {{if eq $.CurrentSubsection .}}selected{{end}}>{{.}}</option>
                {{end}}
              </select>
            </label>

            <label class="field">
              <span>Заголовок</span>
              <input name="title" type="text" maxlength="180" placeholder="Например: Как починить systemd unit после деплоя" value="{{.ArticleTitle}}" required />
            </label>

            <label class="field">
              <span>Текст статьи</span>
              <textarea name="body" data-md-editor="true" rows="15" placeholder="Проблема, шаги, команда, проверка результата...">{{.ArticleBody}}</textarea>
              <small class="field-hint">Markdown: `# заголовок`, `**жирный**`, `![alt](https://image-url)`</small>
            </label>

            <div class="atlas-actions">
              <button class="button button-primary" type="submit">Сохранить статью</button>
              <a class="button button-ghost" href="/app/section?slug={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">Отмена</a>
            </div>
            <p class="atlas-autosave-status" data-autosave-status aria-live="polite"></p>
          </form>
        </article>
      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>© Контур знаний, все права защищены.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
  <script src="{{asset "markdown-editor.js"}}"></script>
  <script src="{{asset "editor-autosave.js"}}"></script>
</body>
</html>
