<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} · {{.AppName}}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark">KZ</div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">Контур знаний</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        <span class="atlas-user-chip">@{{.User.Name}}</span>
        <form method="post" action="/auth/logout">
          <button class="button button-ghost" type="submit">Выйти</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <p class="panel-label">Разделы</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="Найти раздел или тему..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>Ничего не нашлось. Попробуйте другое слово.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-article-view-head">
          <p class="panel-label">Статья</p>
          <h2 class="atlas-section-title">{{.CurrentArticle.Title}}</h2>
          <div class="atlas-article-view-meta">
            <span class="atlas-meta-chip">Раздел: {{.CurrentArticle.SectionName}}</span>
            {{if .CurrentArticle.Subsection}}
              <span class="atlas-meta-chip">Подраздел: {{.CurrentArticle.Subsection}}</span>
            {{end}}
            <span class="atlas-meta-chip">Автор: {{.CurrentArticle.AuthorName}}</span>
            <span class="atlas-meta-chip">Обновлено: {{.CurrentArticle.UpdatedAt.Format "02.01.2006 15:04"}}</span>
          </div>
          <div class="atlas-actions">
            <a class="button button-ghost button-compact" href="/app/section?slug={{.CurrentArticle.SectionSlug}}{{if .CurrentArticle.Subsection}}&sub={{urlquery .CurrentArticle.Subsection}}{{end}}">Назад в раздел</a>
            {{if eq .User.ID .CurrentArticle.AuthorID}}
              <a class="button button-ghost button-compact" href="/app/article/edit?id={{.CurrentArticle.ID}}">Редактировать</a>
            {{end}}
          </div>
        </article>

        <article class="atlas-card">
          <div class="atlas-article-view-body">{{.CurrentArticle.Body}}</div>
        </article>
      </section>
    </section>
  </main>
  <script src="{{asset "wiki-ui.js"}}"></script>
</body>
</html>
