<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">袣芯薪褌褍褉 蟹薪邪薪懈泄</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        {{if .User.IsAdmin}}
          <a class="button button-ghost" href="/app/admin/users">袗写屑懈薪泻邪</a>
        {{end}}
        <a class="button button-ghost" href="/app/search?section={{.CurrentArticle.SectionSlug}}{{if .CurrentArticle.Subsection}}&sub={{urlquery .CurrentArticle.Subsection}}{{end}}">袩芯懈褋泻</a>
        <form method="post" action="/auth/logout">
          <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
          <button class="button button-ghost" type="submit">袙褘泄褌懈</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="袨褌泻褉褘褌褜 锌褉芯褎懈谢褜 @{{.User.Name}}" title="袪械泄褌懈薪谐: {{.User.EffectiveRating}}, 蟹胁邪薪懈械: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="袗胁邪褌邪褉 @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}} &middot; {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">念 {{.User.NextRankLabel}}: 铖蜞腩顸 {{.User.RatingToNextRank}}</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">锑犟桁嚯铄 玮囗桢 漕耱桡眢蝾</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="袧邪褋褌褉芯泄泻懈 锌褉芯褎懈谢褟" title="袧邪褋褌褉芯泄泻懈 锌褉芯褎懈谢褟">&#9881;</a>
          </div>
          <p class="panel-label">袪邪蟹写械谢褘</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="袧邪泄褌懈 褉邪蟹写械谢 懈谢懈 褌械屑褍..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>袧懈褔械谐芯 薪械 薪邪褕谢芯褋褜. 袩芯锌褉芯斜褍泄褌械 写褉褍谐芯械 褋谢芯胁芯.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-article-view-head">
          <p class="panel-label">小褌邪褌褜褟</p>
          <h2 class="atlas-section-title">{{.CurrentArticle.Title}}</h2>
          <div class="atlas-article-view-meta">
            <span class="atlas-meta-chip">袪邪蟹写械谢: {{.CurrentArticle.SectionName}}</span>
            {{if .CurrentArticle.Subsection}}
              <span class="atlas-meta-chip">袩芯写褉邪蟹写械谢: {{.CurrentArticle.Subsection}}</span>
            {{end}}
            <span class="atlas-meta-chip">袗胁褌芯褉: {{.CurrentArticle.AuthorName}}</span>
            <span class="atlas-meta-chip">袥邪泄泻懈: {{.ArticleLikeCount}}</span>
            <span class="atlas-meta-chip">袨斜薪芯胁谢械薪芯: {{.CurrentArticle.UpdatedAt.Format "02.01.2006 15:04"}}</span>
          </div>
          <div class="atlas-actions">
            <a class="button button-ghost button-compact" href="/app/section?slug={{.CurrentArticle.SectionSlug}}{{if .CurrentArticle.Subsection}}&sub={{urlquery .CurrentArticle.Subsection}}{{end}}">袧邪蟹邪写 胁 褉邪蟹写械谢</a>
            {{if ne .User.ID .CurrentArticle.AuthorID}}
              <form method="post" action="/app/article/like" class="atlas-like-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
                <input type="hidden" name="article_id" value="{{.CurrentArticle.ID}}" />
                <input type="hidden" name="action" value="{{if .ArticleLikedByUser}}unlike{{else}}like{{end}}" />
                <button class="button button-ghost button-compact {{if .ArticleLikedByUser}}atlas-like-button-active{{end}}" type="submit">
                  {{if .ArticleLikedByUser}}校斜褉邪褌褜 谢邪泄泻{{else}}袥邪泄泻 +10 邪胁褌芯褉褍{{end}}
                </button>
              </form>
            {{else}}
              <span class="atlas-meta-chip">小胁芯褞 褋褌邪褌褜褞 谢邪泄泻薪褍褌褜 薪械谢褜蟹褟</span>
            {{end}}
            {{if and .User.CanEdit (or (eq .User.ID .CurrentArticle.AuthorID) .User.IsAdmin)}}
              <a class="button button-ghost button-compact" href="/app/article/edit?id={{.CurrentArticle.ID}}">袪械写邪泻褌懈褉芯胁邪褌褜</a>
            {{end}}
            {{if .User.CanEdit}}
              <form method="post" action="/app/article/delete" onsubmit="return confirm('校写邪谢懈褌褜 褋褌邪褌褜褞? 协褌芯 写械泄褋褌胁懈械 薪械芯斜褉邪褌懈屑芯.');">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
                <input type="hidden" name="article_id" value="{{.CurrentArticle.ID}}" />
                <button class="button button-ghost button-compact atlas-danger-button" type="submit">校写邪谢懈褌褜</button>
              </form>
            {{end}}
          </div>
        </article>

        {{if .Error}}
          <p class="alert alert-error">{{.Error}}</p>
        {{end}}
        {{if .Success}}
          <p class="alert alert-success">{{.Success}}</p>
        {{end}}

        <article class="atlas-card">
          <div class="atlas-article-view-body">{{.ArticleBodyHTML}}</div>
        </article>

        <article class="atlas-card atlas-comments-card">
          <div class="atlas-recent-head">
            <p class="panel-label">袣芯屑屑械薪褌邪褉懈懈 泻芯屑邪薪写褘</p>
            {{if .ArticleComments}}
              <span class="atlas-recent-count">{{len .ArticleComments}}</span>
            {{end}}
          </div>

          <form class="atlas-comment-form" method="post" action="/app/article/comment/add">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
            <input type="hidden" name="article_id" value="{{.CurrentArticle.ID}}" />
            <label class="field">
              <span>袛芯斜邪胁懈褌褜 泻芯屑屑械薪褌邪褉懈泄</span>
              <textarea name="body" rows="4" maxlength="2000" placeholder="袧邪锌懈褕懈褌械 泻芯褉芯褌泻芯, 褔褌芯 胁邪卸薪芯 泻芯屑邪薪写械: 褉械褕械薪懈械, 泻芯薪褌械泻褋褌, 锌芯写胁芯写薪褘械 泻邪屑薪懈..." required></textarea>
            </label>
            <div class="atlas-actions">
              <button class="button button-primary button-compact" type="submit">袨褌锌褉邪胁懈褌褜</button>
            </div>
          </form>

          {{if .ArticleComments}}
            <div class="atlas-comment-list">
              {{range .ArticleComments}}
                <article class="atlas-comment-item">
                  <div class="atlas-comment-head">
                    <p class="atlas-comment-author">{{.Author}}</p>
                    <p class="atlas-comment-meta">{{.CreatedAt.Format "02.01.2006 15:04"}}</p>
                  </div>
                  <div class="atlas-comment-body">{{markdown .Body}}</div>
                  {{if .CanDelete}}
                    <form method="post" action="/app/article/comment/delete" onsubmit="return confirm('校写邪谢懈褌褜 泻芯屑屑械薪褌邪褉懈泄?');">
                      <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                      <input type="hidden" name="article_id" value="{{$.CurrentArticle.ID}}" />
                      <input type="hidden" name="comment_id" value="{{.ID}}" />
                      <button class="button button-ghost button-compact atlas-danger-button" type="submit">校写邪谢懈褌褜</button>
                    </form>
                  {{end}}
                </article>
              {{end}}
            </div>
          {{else}}
            <p class="atlas-empty">袣芯屑屑械薪褌邪褉懈械胁 锌芯泻邪 薪械褌. 袛芯斜邪胁褜褌械 锌械褉胁褍褞 蟹邪屑械褌泻褍 写谢褟 泻芯屑邪薪写褘.</p>
          {{end}}
        </article>

      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>漏 袣芯薪褌褍褉 蟹薪邪薪懈泄, 胁褋械 锌褉邪胁邪 蟹邪褖懈褖械薪褘.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
</body>
</html>

