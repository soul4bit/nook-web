<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">Контур знаний</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        {{if .User.IsAdmin}}
          <a class="button button-ghost" href="/app/admin/users">Админка</a>
        {{end}}
        <a class="button button-ghost" href="/app/search?section={{.CurrentArticle.SectionSlug}}{{if .CurrentArticle.Subsection}}&sub={{urlquery .CurrentArticle.Subsection}}{{end}}">Поиск</a>
        <form method="post" action="/auth/logout">
          <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
          <button class="button button-ghost" type="submit">Выйти</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="Открыть профиль @{{.User.Name}}" title="Рейтинг: {{.User.EffectiveRating}}, звание: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="Аватар @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}} &middot; {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">До следующего звания &laquo;{{.User.NextRankLabel}}&raquo;: {{.User.RatingToNextRank}} очков</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">Максимальное звание достигнуто</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="Настройки профиля" title="Настройки профиля">&#9881;</a>
          </div>
          <p class="panel-label">Разделы</p>
          <p class="atlas-sidebar-hint">Быстрая навигация по базе знаний</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="Найти раздел или тему..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>Ничего не нашлось. Попробуйте другое слово.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-article-view-head">
          <p class="panel-label">Статья</p>
          <h2 class="atlas-section-title">{{.CurrentArticle.Title}}</h2>
          <div class="atlas-article-view-meta">
            <span class="atlas-meta-chip">Раздел: {{.CurrentArticle.SectionName}}</span>
            {{if .CurrentArticle.Subsection}}
              <span class="atlas-meta-chip">Подраздел: {{.CurrentArticle.Subsection}}</span>
            {{end}}
            <span class="atlas-meta-chip">Автор: {{.CurrentArticle.AuthorName}}</span>
            <span class="atlas-meta-chip">Лайки: {{.ArticleLikeCount}}</span>
            <span class="atlas-meta-chip">Обновлено: {{.CurrentArticle.UpdatedAt.Format "02.01.2006 15:04"}}</span>
          </div>
          <div class="atlas-actions">
            <a class="button button-ghost button-compact" href="/app/section?slug={{.CurrentArticle.SectionSlug}}{{if .CurrentArticle.Subsection}}&sub={{urlquery .CurrentArticle.Subsection}}{{end}}">Назад в раздел</a>
            {{if ne .User.ID .CurrentArticle.AuthorID}}
              <form method="post" action="/app/article/like" class="atlas-like-form">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
                <input type="hidden" name="article_id" value="{{.CurrentArticle.ID}}" />
                <input type="hidden" name="action" value="{{if .ArticleLikedByUser}}unlike{{else}}like{{end}}" />
                <button class="button button-ghost button-compact {{if .ArticleLikedByUser}}atlas-like-button-active{{end}}" type="submit">
                  {{if .ArticleLikedByUser}}Убрать лайк{{else}}Лайк +10 автору{{end}}
                </button>
              </form>
            {{else}}
              <span class="atlas-meta-chip">Свою статью лайкнуть нельзя</span>
            {{end}}
            {{if and .User.CanEdit (or (eq .User.ID .CurrentArticle.AuthorID) .User.IsAdmin)}}
              <a class="button button-ghost button-compact" href="/app/article/edit?id={{.CurrentArticle.ID}}">Редактировать</a>
            {{end}}
            {{if .User.CanEdit}}
              <form method="post" action="/app/article/delete" onsubmit="return confirm('Удалить статью? Это действие необратимо.');">
                <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
                <input type="hidden" name="article_id" value="{{.CurrentArticle.ID}}" />
                <button class="button button-ghost button-compact atlas-danger-button" type="submit">Удалить</button>
              </form>
            {{end}}
          </div>
        </article>

        {{if .Error}}
          <p class="alert alert-error">{{.Error}}</p>
        {{end}}
        {{if .Success}}
          <p class="alert alert-success">{{.Success}}</p>
        {{end}}

        <article class="atlas-card">
          <div class="atlas-article-view-body">{{.ArticleBodyHTML}}</div>
        </article>

        <article class="atlas-card atlas-comments-card">
          <div class="atlas-recent-head">
            <p class="panel-label">Комментарии команды</p>
            {{if .ArticleComments}}
              <span class="atlas-recent-count">{{len .ArticleComments}}</span>
            {{end}}
          </div>

          <form class="atlas-comment-form" method="post" action="/app/article/comment/add">
            <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
            <input type="hidden" name="article_id" value="{{.CurrentArticle.ID}}" />
            <label class="field">
              <span>Добавить комментарий</span>
              <textarea name="body" rows="4" maxlength="2000" placeholder="Напишите коротко, что важно команде: решение, контекст, подводные камни..." required></textarea>
            </label>
            <div class="atlas-actions">
              <button class="button button-primary button-compact" type="submit">Отправить</button>
            </div>
          </form>

          {{if .ArticleComments}}
            <div class="atlas-comment-list">
              {{range .ArticleComments}}
                <article class="atlas-comment-item">
                  <div class="atlas-comment-head">
                    <p class="atlas-comment-author">{{.Author}}</p>
                    <p class="atlas-comment-meta">{{.CreatedAt.Format "02.01.2006 15:04"}}</p>
                  </div>
                  <div class="atlas-comment-body">{{markdown .Body}}</div>
                  {{if .CanDelete}}
                    <form method="post" action="/app/article/comment/delete" onsubmit="return confirm('Удалить комментарий?');">
                      <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                      <input type="hidden" name="article_id" value="{{$.CurrentArticle.ID}}" />
                      <input type="hidden" name="comment_id" value="{{.ID}}" />
                      <button class="button button-ghost button-compact atlas-danger-button" type="submit">Удалить</button>
                    </form>
                  {{end}}
                </article>
              {{end}}
            </div>
          {{else}}
            <p class="atlas-empty">Комментариев пока нет. Добавьте первую заметку для команды.</p>
          {{end}}
        </article>

      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>© Контур знаний, все права защищены.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
</body>
</html>

