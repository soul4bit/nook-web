<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">–ö–Ψ–Ϋ―²―É―Ä –Ζ–Ϋ–Α–Ϋ–Η–Ι</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        {{if .User.IsAdmin}}
          <a class="button button-ghost" href="/app/admin/users">–ê–¥–Φ–Η–Ϋ–Κ–Α</a>
        {{end}}
        <a class="button button-ghost" href="/app/search?section={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">–ü–Ψ–Η―¹–Κ</a>
        <form method="post" action="/auth/logout">
          <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
          <button class="button button-ghost" type="submit">–£―΄–Ι―²–Η</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="–û―²–Κ―Ä―΄―²―¨ –Ω―Ä–Ψ―³–Η–Μ―¨ @{{.User.Name}}" title="–†–Β–Ι―²–Η–Ϋ–≥: {{.User.EffectiveRating}}, –Ζ–≤–Α–Ϋ–Η–Β: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="–ê–≤–Α―²–Α―Ä @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}} &middot; {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">Ρν {{.User.NextRankLabel}}: νώρύκνώϋ {{.User.RatingToNextRank}}</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">Χύξώηλύκϋμνε γβύμηε δνώρηψμσρν</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="–ù–Α―¹―²―Ä–Ψ–Ι–Κ–Η –Ω―Ä–Ψ―³–Η–Μ―è" title="–ù–Α―¹―²―Ä–Ψ–Ι–Κ–Η –Ω―Ä–Ψ―³–Η–Μ―è">&#9881;</a>
          </div>
          <p class="panel-label">–†–Α–Ζ–¥–Β–Μ―΄</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="–ù–Α–Ι―²–Η ―Ä–Α–Ζ–¥–Β–Μ –Η–Μ–Η ―²–Β–Φ―É..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>–ù–Η―΅–Β–≥–Ψ –Ϋ–Β –Ϋ–Α―à–Μ–Ψ―¹―¨. –ü–Ψ–Ω―Ä–Ψ–±―É–Ι―²–Β –¥―Ä―É–≥–Ψ–Β ―¹–Μ–Ψ–≤–Ψ.</p>
        </article>
      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-main-head">
          <p class="panel-label">–†–Α–Ζ–¥–Β–Μ</p>
          <h2 class="atlas-section-title">{{.CurrentSection.Name}}</h2>
          {{if .CurrentSubsection}}
            <p class="atlas-sub-current">–ü–Ψ–¥―Ä–Α–Ζ–¥–Β–Μ: {{.CurrentSubsection}}</p>
          {{end}}
          <p class="atlas-hero-text">–Γ–Ψ–±–Η―Ä–Α–Ι―²–Β ―Ä–Α–±–Ψ―΅–Η–Β –Ζ–Α–Φ–Β―²–Κ–Η –Κ–Ψ―Ä–Ψ―²–Κ–Ψ –Η –Κ–Ψ–Ϋ–Κ―Ä–Β―²–Ϋ–Ψ, ―΅―²–Ψ–±―΄ –≤–Ψ–Ζ–≤―Ä–Α―â–Α―²―¨―¹―è –Κ –Ϋ–Η–Φ –±–Β–Ζ –±–Ψ–Μ–Η.</p>

          <div class="atlas-sub-pills">
            {{range .CurrentSection.Subsections}}
              <a class="atlas-sub-pill {{if eq $.CurrentSubsection .}}atlas-sub-pill-active{{end}}" href="/app/section?slug={{$.CurrentSection.Slug}}&sub={{urlquery .}}">{{.}}</a>
            {{end}}
          </div>

          {{if .User.CanEdit}}
            <div class="atlas-actions">
              <a class="button button-new-article" href="/app/article/new?section={{.CurrentSection.Slug}}{{if .CurrentSubsection}}&sub={{urlquery .CurrentSubsection}}{{end}}">+ –ù–Ψ–≤–Α―è ―¹―²–Α―²―¨―è</a>
            </div>
          {{end}}
        </article>

        {{if .Success}}
          <p class="alert alert-success">{{.Success}}</p>
        {{end}}

        {{if .SectionArticles}}
          <div class="atlas-article-list">
            {{range .SectionArticles}}
              <article class="atlas-card atlas-article-card">
                <div class="atlas-article-meta">
                  <span>–ê–≤―²–Ψ―Ä: {{.AuthorName}}</span>
                  <span>{{.UpdatedAt.Format "02.01.2006 15:04"}}</span>
                </div>
                {{if .Subsection}}
                  <p class="atlas-article-subsection">–ü–Ψ–¥―Ä–Α–Ζ–¥–Β–Μ: {{.Subsection}}</p>
                {{end}}
                <h3><a class="atlas-article-title-link" href="/app/article?id={{.ID}}">{{.Title}}</a></h3>
                <div class="atlas-article-body atlas-md-snippet">{{markdown .Body}}</div>
                <div class="atlas-article-actions">
                  <a class="button button-ghost button-compact" href="/app/article?id={{.ID}}">–û―²–Κ―Ä―΄―²―¨</a>
                  {{if and $.User.CanEdit (or (eq $.User.ID .AuthorID) $.User.IsAdmin)}}
                    <a class="button button-ghost button-compact" href="/app/article/edit?id={{.ID}}">–†–Β–¥–Α–Κ―²–Η―Ä–Ψ–≤–Α―²―¨</a>
                  {{end}}
                  {{if $.User.CanEdit}}
                    <form method="post" action="/app/article/delete" onsubmit="return confirm('–Θ–¥–Α–Μ–Η―²―¨ ―¹―²–Α―²―¨―é? –≠―²–Ψ –¥–Β–Ι―¹―²–≤–Η–Β –Ϋ–Β–Ψ–±―Ä–Α―²–Η–Φ–Ψ.');">
                      <input type="hidden" name="csrf_token" value="{{$.CSRFToken}}" />
                      <input type="hidden" name="article_id" value="{{.ID}}" />
                      <button class="button button-ghost button-compact atlas-danger-button" type="submit">–Θ–¥–Α–Μ–Η―²―¨</button>
                    </form>
                  {{end}}
                </div>
              </article>
            {{end}}
          </div>
        {{else}}
          <article class="atlas-card">
            {{if .User.CanEdit}}
              <p class="atlas-empty">–£ ―ç―²–Ψ–Φ ―Ä–Α–Ζ–¥–Β–Μ–Β –Ω–Ψ–Κ–Α –Ϋ–Β―² ―¹―²–Α―²–Β–Ι. –ù–Α–Ε–Φ–Η―²–Β ¬Ϊ–ù–Ψ–≤–Α―è ―¹―²–Α―²―¨―è¬Μ –Η –¥–Ψ–±–Α–≤―¨―²–Β –Ω–Β―Ä–≤―É―é.</p>
            {{else}}
              <p class="atlas-empty">–£ ―ç―²–Ψ–Φ ―Ä–Α–Ζ–¥–Β–Μ–Β –Ω–Ψ–Κ–Α –Ϋ–Β―² ―¹―²–Α―²–Β–Ι. –Θ –≤–Α―¹ ―Ä–Ψ–Μ―¨ ―²–Ψ–Μ―¨–Κ–Ψ –Ϋ–Α –Ω―Ä–Ψ―¹–Φ–Ψ―²―Ä.</p>
            {{end}}
          </article>
        {{end}}
      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>¬© –ö–Ψ–Ϋ―²―É―Ä –Ζ–Ϋ–Α–Ϋ–Η–Ι, –≤―¹–Β –Ω―Ä–Α–≤–Α –Ζ–Α―â–Η―â–Β–Ϋ―΄.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
</body>
</html>

