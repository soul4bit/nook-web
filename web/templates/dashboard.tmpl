<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{.Title}} - {{.AppName}}</title>
  <link rel="icon" href="{{asset "favicon.svg"}}" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@500;600&family=Manrope:wght@500;600;700;800&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="{{asset "app.css"}}" />
</head>
<body class="app-page">
  <main class="atlas-shell">
    <header class="atlas-topbar">
      <a class="atlas-brand atlas-brand-link" href="/app">
        <div class="atlas-mark atlas-mark-image" aria-hidden="true"><img class="atlas-mark-img" src="{{asset "logo-mark.svg"}}" alt="" /></div>
        <div>
          <p class="eyebrow">{{.AppName}}</p>
          <h1 class="atlas-heading">Контур знаний</h1>
        </div>
      </a>

      <div class="atlas-topbar-meta">
        {{if .User.IsAdmin}}
          <a class="button button-ghost" href="/app/admin/users">Админка</a>
        {{end}}
        <a class="button button-ghost" href="/app/search">Поиск</a>
        <form method="post" action="/auth/logout">
          <input type="hidden" name="csrf_token" value="{{.CSRFToken}}" />
          <button class="button button-ghost" type="submit">Выйти</button>
        </form>
      </div>
    </header>

    <section class="atlas-layout atlas-layout-two">
      <aside class="atlas-rail">
        <article class="atlas-card atlas-sections-sidebar">
          <div class="atlas-sidebar-profile atlas-user-chip-rank-{{.User.RankClass}}">
            <a class="atlas-sidebar-profile-main" href="/app/profile" aria-label="Открыть профиль @{{.User.Name}}" title="Рейтинг: {{.User.EffectiveRating}}, звание: {{.User.RankLabel}}">
              {{if .User.AvatarURL}}
                <img class="atlas-sidebar-profile-avatar" src="{{.User.AvatarURL}}" alt="Аватар @{{.User.Name}}" loading="lazy" />
              {{else}}
                <span class="atlas-sidebar-profile-avatar atlas-sidebar-profile-initial">{{if .User.Name}}{{printf "%.1s" .User.Name}}{{else}}?{{end}}</span>
              {{end}}
              <span class="atlas-sidebar-profile-copy">
                <span class="atlas-sidebar-profile-name">@{{.User.Name}}</span>
                <span class="atlas-sidebar-profile-rank">{{.User.RankLabel}}</span>
                <span class="atlas-sidebar-profile-points">Рейтинг: {{.User.EffectiveRating}}</span>
                {{if .User.HasNextRank}}
                  <span class="atlas-sidebar-profile-progress-label">До следующего звания &laquo;{{.User.NextRankLabel}}&raquo;: {{.User.RatingToNextRank}} очков</span>
                  <span class="atlas-sidebar-profile-progress" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: {{.User.RankProgressPercent}}%;"></span>
                  </span>
                {{else}}
                  <span class="atlas-sidebar-profile-progress-label">Максимальное звание достигнуто</span>
                  <span class="atlas-sidebar-profile-progress atlas-sidebar-profile-progress-max" role="presentation" aria-hidden="true">
                    <span class="atlas-sidebar-profile-progress-fill" style="width: 100%;"></span>
                  </span>
                {{end}}
              </span>
            </a>
            <a class="atlas-sidebar-profile-settings" href="/app/profile" aria-label="Настройки профиля" title="Настройки профиля">&#9881;</a>
          </div>
          <div class="atlas-sidebar-heading">
            <p class="panel-label">Разделы</p>
            <span class="atlas-sidebar-count">{{len .Sections}}</span>
          </div>
          <p class="atlas-sidebar-hint">Быстрая навигация по базе знаний</p>
          <label class="atlas-nav-search-wrap">
            <input class="atlas-nav-search" type="search" placeholder="Поиск по разделам и темам..." />
          </label>
          <ul class="atlas-nav">
            {{range .Sections}}
              {{$section := .}}
              <li class="atlas-nav-item {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-item-active{{end}}">
                <a class="atlas-nav-link {{if eq $.CurrentSectionSlug $section.Slug}}atlas-nav-link-active{{end}}" href="/app/section?slug={{$section.Slug}}">
                  <span class="atlas-nav-title">{{$section.Name}}</span>
                </a>
                <ul class="atlas-nav-sub">
                  {{range $section.Subsections}}
                    <li>
                      <a class="atlas-sub-link {{if and (eq $.CurrentSectionSlug $section.Slug) (eq $.CurrentSubsection .)}}atlas-sub-link-active{{end}}" href="/app/section?slug={{$section.Slug}}&sub={{urlquery .}}">{{.}}</a>
                    </li>
                  {{end}}
                </ul>
              </li>
            {{end}}
          </ul>
          <p class="atlas-nav-empty" data-nav-empty hidden>Ничего не нашлось. Попробуйте другое слово.</p>
        </article>

      </aside>

      <section class="atlas-main">
        <article class="atlas-card atlas-hero atlas-hero-devops">
          <div class="atlas-hero-grid">
            <div class="atlas-hero-copy">
              <p class="panel-label">Дежурка: мем-режим</p>
              <h2 class="atlas-hero-title">Рукбук для тех, кто любит стабильный прод и шутки про “не деплоим в пятницу”.</h2>
              <p class="atlas-hero-text">
                Команды, постмортемы и практические фиксы в одном месте: меньше хаоса в чате,
                быстрее восстановление и релизы без сюрпризов в 03:00.
              </p>
              <div class="atlas-hero-motto">
                <p class="atlas-hero-motto-label">Рофл-монитор</p>
                <p class="atlas-hero-motto-text">Если всё зелёное уже третьи сутки, сначала проверьте: мониторинг точно не уснул?</p>
              </div>
              <div class="atlas-pill-row atlas-hero-pills">
                <span class="atlas-pill">Разделов: {{len .Sections}}</span>
                <span class="atlas-pill">В ленте: {{len .RecentArticles}}</span>
                <span class="atlas-pill">Роль: {{.ProfileRoleLabel}}</span>
              </div>
              <div class="atlas-actions atlas-hero-actions">
                {{if .SectionOverviews}}
                  <a class="button button-ghost button-compact" href="/app/section?slug={{(index .SectionOverviews 0).Slug}}">Открыть базу</a>
                {{end}}
                {{if .User.CanEdit}}
                  <a class="button button-new-article button-compact" href="/app/article/new{{if .SectionOverviews}}?section={{(index .SectionOverviews 0).Slug}}{{end}}">+ Новая статья</a>
                {{end}}
              </div>
            </div>
            <div class="atlas-ops-panel" aria-hidden="true">
              <p class="atlas-ops-head">статус.пайплайна</p>
              <ul class="atlas-ops-list">
                <li><span class="atlas-ops-dot atlas-ops-dot-ok"></span>алерты: тихо</li>
                <li><span class="atlas-ops-dot atlas-ops-dot-ok"></span>ошибки: низко</li>
                <li><span class="atlas-ops-dot atlas-ops-dot-warn"></span>деплой-в-пятницу: блок</li>
                <li><span class="atlas-ops-dot atlas-ops-dot-live"></span>синхронизация-рукбука: активна</li>
              </ul>
              <div class="atlas-ops-log">
                <span>$ kubectl apply -f runbook-sync.yaml</span>
                <span>синхронизация: {{len .RecentArticles}} записей</span>
                <span>статус: зелёный</span>
              </div>
              <div class="atlas-ops-tape">
                <span>[11:32] разбор-инцидента обновлён</span>
                <span>[11:41] план-отката найден, паники нет</span>
                <span>[11:47] прод жив, кофе тоже</span>
              </div>
            </div>
          </div>
        </article>

        {{if .Success}}
          <p class="alert alert-success">{{.Success}}</p>
        {{end}}

        <article class="atlas-card atlas-recent-card">
          <div class="atlas-recent-head">
            <div class="atlas-recent-title-wrap">
              <p class="panel-label">Последние статьи</p>
              <p class="atlas-recent-note">Свежие апдейты по инфраструктуре: что починили, что оптимизировали и как больше не повторять тот же квест.</p>
            </div>
            {{if .RecentArticles}}
              <span class="atlas-recent-count">{{len .RecentArticles}} в ленте</span>
            {{end}}
          </div>
          {{if .RecentArticles}}
            <div class="atlas-article-list atlas-recent-list">
              {{range .RecentArticles}}
                <article class="atlas-article-card atlas-recent-item">
                  <div class="atlas-article-meta">
                    <span class="atlas-recent-path">{{.SectionName}}{{if .Subsection}} / {{.Subsection}}{{end}}</span>
                    <span class="atlas-recent-date">{{.UpdatedAt.Format "02.01.2006 15:04"}}</span>
                  </div>
                  <h3><a class="atlas-article-title-link" href="/app/article?id={{.ID}}">{{.Title}}</a></h3>
                  <div class="atlas-article-body atlas-recent-body atlas-md-snippet">{{markdown .Body}}</div>
                  <div class="atlas-article-actions atlas-recent-actions">
                    <p class="atlas-article-author atlas-recent-author">Автор: {{.AuthorName}}</p>
                    <a class="button button-ghost button-compact" href="/app/article?id={{.ID}}">Открыть</a>
                  </div>
                </article>
              {{end}}
            </div>
          {{else}}
            <p class="atlas-empty">Пока пусто. Создайте первую статью из любого раздела.</p>
          {{end}}
        </article>
      </section>
    </section>
  </main>
  <footer class="atlas-site-footer">
    <span>© Контур знаний, все права защищены.</span>
    <a class="atlas-site-footer-link" href="https://github.com/soul4bit/kontur-znaniy" target="_blank" rel="noopener noreferrer">GitHub: soul4bit/kontur-znaniy</a>
  </footer>
  <script src="{{asset "wiki-ui.js"}}"></script>
</body>
</html>
